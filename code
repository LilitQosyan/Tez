 #include <iostream>
 #include <vector>
 #include <cmath>

 typedef std::vector<std::vector<double>> Matrix;
 typedef std::vector<double> Vector;

 // Մատրից-վեկտոր բազմապատկման ֆունկցիա
 Vector matvec(const Matrix& M, const Vector& v) {
    int n = v.size();
    Vector res(n, 0.0);
    for (int i = 0; i < n; ++i)
        for (int j = 0; j < n; ++j)
            res[i] += M[i][j] * v[j];
    return res;
 }

 // Վեկտորների գումարում
 Vector vecadd(const Vector& a, const Vector& b) {
    int n = a.size();
    Vector res(n);
    for (int i = 0; i < n; ++i)
        res[i] = a[i] + b[i];
    return res;
 }

 // Վեկտորների սկալяр արտադրյալ
 double dot(const Vector& a, const Vector& b) {
    double sum = 0.0;
    for (size_t i = 0; i < a.size(); ++i)
        sum += a[i] * b[i];
    return sum;
 }

 int main() {
    int n, steps;
    std::cout << "Մուտքագրեք վեկտորի չափը (n): ";
    std::cin >> n;
    std::cout << "Մուտքագրեք քայլերի քանակը (steps): ";
    std::cin >> steps;

    Matrix A(n, Vector(n)), B(n, Vector(n));
    std::cout << "Մուտքագրեք A մատրիցը (յուրաքանչյուր տողը առանձին՝ " << n << " թիվ մեկ տողում):\n";
    for (int i = 0; i < n; ++i) {
        std::cout << "A-ի " << i+1 << "-րդ տողը: ";
        for (int j = 0; j < n; ++j)
            std::cin >> A[i][j];
    }

    std::cout << "Մուտքագրեք B մատրիցը (յուրաքանչյուր տողը առանձին՝ " << n << " թիվ մեկ տողում):\n";
    for (int i = 0; i < n; ++i) {
        std::cout << "B-ի " << i+1 << "-րդ տողը: ";
        for (int j = 0; j < n; ++j)
            std::cin >> B[i][j];
    }

    Vector x(n), w(n), u(n);

    std::cout << "Մուտքագրեք x0 վեկտորը (մի տողում " << n << " թիվ): ";
    for (int i = 0; i < n; ++i) std::cin >> x[i];

    std::cout << "Մուտքագրեք w վեկտորը (մի տողում " << n << " թիվ): ";
    for (int i = 0; i < n; ++i) std::cin >> w[i];

    std::cout << "Մուտքագրեք u կառավարման վեկտորը (մի տողում " << n << " թիվ): ";
    for (int i = 0; i < n; ++i) std::cin >> u[i];

    for (int k = 0; k < steps; ++k) {
        Vector Ax = matvec(A, x);
        Vector Bu = matvec(B, u);
        Vector x_new = vecadd(Ax, Bu);

        double y = dot(w, x_new);

        std::cout << "Քայլ " << k+1 << ": y = " << y << ", x = [";
        for (int i = 0; i < n; ++i) {
            std::cout << x_new[i];
            if (i != n-1) std::cout << ", ";
        }
        std::cout << "]" << std::endl;

        // Կարող ես այստեղ փոփոխել u-ի արժեքը ըստ կառավարման օրենքի, եթե անհրաժեշտ է

        x = x_new;
    }
    return 0;
 }
